            <div className="pf-card sq"><div className="pf-ph"></div><div className="pf-corner">03 · WORKSPACE</div><div className="pf-corner r">24MM</div><div className="pf-mask"></div><div className="pf-cap"><div className="name">OFFICE ENVIRONMENT</div><div className="cat">BRANDING</div></div></div>
            <div className="pf-card tall"><div className="pf-ph"></div><div className="pf-corner">04 · EVENT</div><div className="pf-corner r">70-200</div><div className="pf-mask"></div><div className="pf-cap"><div className="name">LIVE EVENT</div><div className="cat">COVERAGE</div></div></div>
            <div className="pf-card wide"><div className="pf-ph"></div><div className="pf-corner">05 · FILM</div><div className="pf-corner r">4K · 24P</div><div className="pf-mask"></div><div className="pf-cap"><div className="name">BRAND FILM</div><div className="cat">VIDEOGRAPHY</div></div></div>
            <div className="pf-card sq"><div className="pf-ph"></div><div className="pf-corner">06 · DRONE</div><div className="pf-corner r">AERIAL</div><div className="pf-mask"></div><div className="pf-cap"><div className="name">AERIAL PERSPECTIVE</div><div className="cat">DRONE</div></div></div>
            <div className="pf-card tall"><div className="pf-ph"></div><div className="pf-corner">07 · PRODUCT</div><div className="pf-corner r">90MM</div><div className="pf-mask"></div><div className="pf-cap"><div className="name">PRODUCT IMAGERY</div><div className="cat">E-COMMERCE</div></div></div>
          </div>
          <div className="pf-bar-wrap"><div className="pf-bar" id="pfBar"></div></div>
        </div>
